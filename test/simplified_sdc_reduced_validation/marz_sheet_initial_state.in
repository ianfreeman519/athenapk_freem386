# AthenaPK reduced validation input: reduced MARZ-sheet initial-state dump

<comment>
problem = reduced MARZ-like current-sheet initial-state validation

<job>
problem_id = marz_sheet

<diffusion>
integrator = unsplit
resistivity = ohmic
resistivity_coeff = spitzer
spitzer_log_lambda = 10.0
spitzer_eta_max = 5e6
cfl = 0.2
cfl_diff_heat = 0.2

<cooling>
enable_cooling = none

<units>
code_length_cgs = 1.0
code_mass_cgs = 1.0
code_time_cgs = 1.0

<problem/marz_sheet>
B0 = 4.0e5
Bguide = 5.0e4
rho_in = 4.5e-3
T_in = 1.16e6
v_in = 2.0e6
delta_B = 0.02
delta_v = 0.03
rho_bump = 0.0
delta_rho = 0.02
seed_amplitude = 2.0e2
seed_mode_number = 1
delta_seed = 0.05
use_driven_x1_boundaries = true

<parthenon/mesh>
refinement = none
nghost = 2
nx1 = 65
x1min = -0.12
x1max = 0.12
ix1_bc = marz_sheet_x1_inner
ox1_bc = marz_sheet_x1_outer
nx2 = 32
x2min = -0.12
x2max = 0.12
ix2_bc = periodic
ox2_bc = periodic
nx3 = 1
x3min = -0.01
x3max = 0.01
ix3_bc = periodic
ox3_bc = periodic

<parthenon/meshblock>
nx1 = 65
nx2 = 32
nx3 = 1

<parthenon/time>
integrator = rk1
nlim = 0

<hydro>
fluid = glmmhd
eos = adiabatic
riemann = hlld
reconstruction = plm
gamma = 1.66666666
first_order_flux_correct = false
Tfloor = 1.0e4
mean_molecular_weight = 27
Z = 13

<parthenon/output0>
file_type = hdf5
id = out0
variables = cons, prim, T, curlBz
