<comment>
problem = pulsed_reconnection - freeman 2026

<job>
problem_id = pulsed_reconnection

<diffusion>
integrator = rkl2
resistivity = ohmic          # none (disabled) or ohmic
cfl_diff_heat = 0.5
resistivity_coeff = fixed
ohm_diff_coeff_code = 1e4
# spitzer_log_lambda = 10.0
# spitzer_eta_max = 1e7           # 30x the value of the initial temp - should be hottest in the layer

<cooling>
enable_cooling = tabular                # To disable, set to `none`
table_filename = free_free_loss_aluminum_ni_1e18_Zbar_3.cooling    # Path to the cooling table (in a text file)
lambda_units_cgs = 1                    # Conversion factor of the cooling rate relative to CGS units

integrator = townsend              # Other possible options are `rk12` and `rk45` for error bound subcycling
max_iter = 1000                    # Max number of iteration for subcycling. Unsued for Townsend integrator
cfl = 0.45                          # Restrict global timestep to `cfl*e / dedt`, i.e., some fraction of change per cycle in the specific internal energy (i.e., temperature)
d_log_temp_tol = 1e-8              # Tolerance in cooling table between subsequent entries. Both subcycling integrators and cfl restriction rely on a table lookup that assumes equally spaced (in log space) temperature values.
d_e_tol = 1e-8                    # Tolerance for the relative error in the change of internal energy for the error bound subcyling integrators (rk12 and rk45). Unused for Townsend integrator.

<units>
code_length_cgs = 1.0 
code_mass_cgs = 1.0
code_time_cgs = 1.0

<problem/pulsed_reconnection>
B0 = 5e5 # 5.0e5   # consistent with MARZ
rho_wire = 2.7e-2  # 0.01 * Aluminum at solid density - this is the peak density
rho_background = 1e-6       # Near vacuum
T_wire = 1.1e4      # Inflow temperature
T_background = 1e1  # Background temperature
v0 = 0        # flow speed away from wires
array_separation = 6

<parthenon/mesh>
refinement = none
nghost = 2

nx1 = 768
x1min = -3
x1max = 3
ix1_bc = outflow
ox1_bc = outflow

nx2 = 512   
x2min = -2.0
x2max = 2.0
ix2_bc = outflow
ox2_bc = outflow

nx3 = 1
x3min = -1
x3max = 1
ix3_bc = periodic
ox3_bc = periodic

# <parthenon/static_refinement0>
# x1min = -2.0
# x1max =  2.0
# x2min = -0.001
# x2max =  0.001
# x3min = -0.0
# x3max =  0.0
# level =  3

<parthenon/meshblock>
nx1 = 128
nx2 = 128
nx3 = 1

<parthenon/time>
integrator = vl2
cfl = 0.45
tlim = 1e-6 # 1000ns
# dt_max = 1e-9

<hydro>
fluid = glmmhd
eos = adiabatic
riemann = hlld
reconstruction = plm
gamma = 1.66666666 # gamma = C_p/C_v
first_order_flux_correct = true
Tfloor = 1e-2

mean_molecular_weight = 27
Z = 13

<parthenon/output0>
file_type = hdf5
dt = 1e-9
id = out0
variables = cons, prim, curlBx, curlBy, curlBz, beta, eta, divv, dt_hyp_fms, dt_hyp_cs, dt_cool_local, dt_heat_local

<parthenon/output1>
file_type = rst
dt = 1e-8
